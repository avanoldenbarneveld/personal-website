{
  "editor.quickSuggestions": {
    "strings": true
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "css.validate": false,
  "scss.validate": false,
  "less.validate": false,
  "postcss.validate": false,
  "tailwindCSS.experimental.classRegex": [
    "tw`([^`]*)",
    "tw\\(([^)]*)\\)",
    "classnames\\(([^)]*)\\)",
    "clsx\\(([^)]*)\\)",
    "\\[([^)]*)\\]"
  ]
}
